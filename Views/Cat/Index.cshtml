@model CatsApp.Models.Cat

<h1 style="text-align:center; font-family:'Times New Roman', serif; color:#ff4da6;">
🐱 Gatitos para todos 🐱
</h1>

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:20px; min-height:80vh;">

    <img src="@Model.url"
         style="
            max-width:90vw;
            max-height:70vh;
            object-fit:contain;
            border-radius:20px;
            box-shadow:0 10px 30px rgba(255,105,180,0.3);
            border: 3px solid #ffd1dc;
         " />

    <button type="button" class="cat-button" onclick="heartsAndReload()">
        🐱 ¡Nuevo gatito! 🐱
    </button>

</div>

<style>
body{
    background-image: url('/images/Entorns fondo 2.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
}

.cat-button{
    padding:12px 24px;
    font-size:16px;
    background-color:#ff4da6;
    color:white;
    border:none;
    border-radius:15px;
    cursor:pointer;
    font-family:Baskerville, serif;
    font-weight:bold;
    transition:0.3s;
    box-shadow:0 5px 15px rgba(255,77,166,0.3);
}

.cat-button:hover{
    background-color:#cdb4ff;
    transform: scale(1.05);
}

@@keyframes floatUp {
    0% {
        transform: translateY(0);
        opacity: 1;
    }
    100% {
        transform: translateY(-120px);
        opacity: 0;
    }
}
</style>

<script>
function heartsAndReload() {
    for (let i = 0; i < 25; i++) {
        let heart = document.createElement("div");
        heart.innerHTML = "💖";

        heart.style.position = "fixed";
        heart.style.left = Math.random() * window.innerWidth + "px";
        heart.style.top = Math.random() * window.innerHeight + "px";
        heart.style.fontSize = (10 + Math.random() * 25) + "px";
        heart.style.pointerEvents = "none";
        heart.style.animation = "floatUp 1.5s ease-out forwards";

        document.body.appendChild(heart);

        setTimeout(() => heart.remove(), 1500);
    }

    setTimeout(() => {
        location.reload();
    }, 300);
}
</script>